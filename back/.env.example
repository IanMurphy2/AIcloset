# Copiá este archivo a `.env` (en back/) y ajustá los valores según tu entorno.
# El backend carga estas variables con dotenv (Config.ts) desde back/.env.

# Entorno de la app: development | production | test
NODE_ENV=development

# Puerto del servidor HTTP
PORT=3000

# --- Base de datos (PostgreSQL) ---
# docker-compose (back/docker-compose.yml) expone Postgres en el puerto host 5433
# (mapea 5433 -> 5432 del contenedor). Por eso, para desarrollo local con
# docker-compose, usá DB_PORT=5433.
DB_HOST=localhost
DB_PORT=5433
DB_USER=user
DB_PASS=password
DB_NAME=closet_db

# --- Subida de imágenes ---
# Carpeta donde se guardan las imágenes subidas (relativa a back/)
UPLOAD_DIR=./uploads
# Tamaño máximo por archivo en bytes (5 MB)
UPLOAD_MAX_SIZE_BYTES=5242880

# --- JWT ---
# IMPORTANTE: cambiá este secreto en producción.
JWT_SECRET=changeme-in-production
JWT_EXPIRES_IN=7d
