{
  "entryFile": "src/api/index.ts",
  "noImplicitAdditionalProperties": "throw-error",
  "controllerPathGlobs": ["src/api/endpoints/**/*Controller.ts"],
  "spec": {
    "outputDirectory": "src/api/tsoa",
    "specVersion": 3,
    "securityDefinitions": {
      "jwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "routes": {
    "routesDir": "src/api/tsoa",
    "authenticationModule": "src/api/middlewares/authentication"
  }
}
